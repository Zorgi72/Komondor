{
  "slug": "k8s-secrets-init-container",
  "description": "K8s manifest uses the secrets-init-container decryption pipeline",
  "filePatterns": [
    "**/*.yaml",
    "**/*.yml"
  ],
  "patterns": [
    {
      "regex": "\\bsecrets-init-container\\b",
      "label": "secrets-init-container image reference",
      "flags": ""
    },
    {
      "regex": "^\\s*name\\s*:\\s*ENCRYPTED_V[12]_[A-Z0-9_]+",
      "label": "ENCRYPTED_V*_ env var (init-container consumer)",
      "flags": ""
    },
    {
      "regex": "^\\s*mountPath\\s*:\\s*[\"']?\\/usr\\/share[\"']?\\s*$",
      "label": "/usr/share decrypted-env mount",
      "flags": ""
    },
    {
      "regex": "\\bdecrypted-env\\b",
      "label": "decrypted-env volume reference",
      "flags": ""
    },
    {
      "regex": "^\\s*name\\s*:\\s*encrypted-v[12]-\\S+",
      "label": "encrypted-v{1,2}-* secret name",
      "flags": ""
    }
  ],
  "source": "k8s-secrets-init-container.ts"
}
