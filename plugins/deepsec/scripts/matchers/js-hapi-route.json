{
  "slug": "js-hapi-route",
  "description": "Hapi server.route configurations (gated on Hapi)",
  "filePatterns": [
    "**/*.{ts,js,mjs,cjs}"
  ],
  "patterns": [
    {
      "regex": "\\bserver\\.route\\s*\\(\\s*\\{",
      "label": "server.route({ method, path, handler })",
      "flags": ""
    },
    {
      "regex": "Hapi\\.server\\s*\\(",
      "label": "Hapi.server() init",
      "flags": ""
    },
    {
      "regex": "options:\\s*\\{\\s*auth:",
      "label": "route auth option (verify scope)",
      "flags": ""
    },
    {
      "regex": "strategy\\s*:\\s*['\"][^'\"]+['\"]",
      "label": "auth strategy declaration",
      "flags": ""
    }
  ],
  "source": "js-hapi-route.ts"
}
