{
  "slug": "go-ssrf",
  "description": "Go HTTP requests with string-concatenated or formatted URLs \u2014 SSRF risk",
  "filePatterns": [
    "**/*.go"
  ],
  "patterns": [
    {
      "regex": "http\\.(Get|Post|Head)\\s*\\(.*\\+",
      "label": "http.Get/Post with string concat URL",
      "flags": ""
    },
    {
      "regex": "http\\.NewRequest\\s*\\(.*fmt\\.Sprintf",
      "label": "http.NewRequest with formatted URL",
      "flags": ""
    },
    {
      "regex": "http\\.NewRequest\\s*\\(.*\\+",
      "label": "http.NewRequest with concatenated URL",
      "flags": ""
    },
    {
      "regex": "url\\.Parse\\s*\\(.*\\+",
      "label": "url.Parse with concatenated string",
      "flags": ""
    },
    {
      "regex": "fmt\\.Sprintf\\s*\\(\\s*\"https?:\\/\\/",
      "label": "URL built via fmt.Sprintf",
      "flags": ""
    }
  ],
  "source": "go-ssrf.ts"
}
