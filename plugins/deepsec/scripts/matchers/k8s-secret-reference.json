{
  "slug": "k8s-secret-reference",
  "description": "K8s manifest references a Secret (secretKeyRef, secretName, ExternalSecret, etc.)",
  "filePatterns": [
    "**/*.yaml",
    "**/*.yml"
  ],
  "patterns": [
    {
      "regex": "^\\s*-?\\s*secretKeyRef\\s*:",
      "label": "env.valueFrom.secretKeyRef",
      "flags": ""
    },
    {
      "regex": "^\\s*secretName\\s*:\\s*\\S",
      "label": "volumes.secret.secretName",
      "flags": ""
    },
    {
      "regex": "^\\s*kind\\s*:\\s*(?:Secret|ExternalSecret|SealedSecret|ClusterSecretStore|SecretStore)\\b",
      "label": "Secret kind manifest",
      "flags": ""
    },
    {
      "regex": "\\bexternal-secrets\\.io\\/",
      "label": "external-secrets.io CRD",
      "flags": ""
    },
    {
      "regex": "\\bvault\\.hashicorp\\.com\\/agent-inject\\b",
      "label": "vault-injector annotation",
      "flags": ""
    },
    {
      "regex": "\\bsecrets-init-container\\b",
      "label": "secrets-init-container reference",
      "flags": ""
    },
    {
      "regex": "^\\s*stringData\\s*:",
      "label": "Secret stringData (plaintext in manifest!)",
      "flags": ""
    }
  ],
  "source": "k8s-secret-reference.ts"
}
